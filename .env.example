# GuildBridge never stores tokens in templates. Keep this file as a sample only.
# Copy to .env and fill in your values locally.

# General
GUILDBRIDGE_REQUEST_TIMEOUT=30
GUILDBRIDGE_MAX_RETRIES=5
GUILDBRIDGE_USER_AGENT="GuildBridge/0.1 (+https://github.com/Yunushan/guildbridge)"

# Discord
DISCORD_API_BASE=https://discord.com/api/v10
DISCORD_BOT_TOKEN=
# DISCORD_TOKEN=  # accepted alias

# Fluxer
FLUXER_API_BASE=https://api.fluxer.app/v1
FLUXER_BOT_TOKEN=
# FLUXER_TOKEN=  # accepted alias

# Stoat / Revolt-compatible deployments
STOAT_API_BASE=https://api.stoat.chat
STOAT_BOT_TOKEN=
# STOAT_TOKEN=   # accepted alias
# REVOLT_API_BASE=
# REVOLT_TOKEN=

# Matrix / Element
MATRIX_BASE_URL=https://matrix.org
MATRIX_SERVER_NAME=matrix.org
MATRIX_ACCESS_TOKEN=
# ELEMENT_MATRIX_BASE_URL=  # accepted alias
# ELEMENT_ACCESS_TOKEN=     # accepted alias

# Rocket.Chat
ROCKET_CHAT_API_BASE=http://localhost:3000/api/v1
ROCKET_CHAT_AUTH_TOKEN=
ROCKET_CHAT_USER_ID=
# ROCKETCHAT_API_BASE=      # accepted alias
# ROCKETCHAT_AUTH_TOKEN=    # accepted alias
# ROCKETCHAT_USER_ID=       # accepted alias

# Mumble / Murmur admin API bridge
# Mumble's voice protocol is not an HTTP management API. Point this at your
# Murmur/Ice/gRPC-to-HTTP admin bridge that exposes server, channel, group, and ACL routes.
MUMBLE_API_BASE=http://localhost:64738/api/v1
MUMBLE_API_TOKEN=
