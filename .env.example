# GuildBridge never stores tokens in templates. Keep this file as a sample only.
# Copy to .env and fill in your values locally.

# General
GUILDBRIDGE_REQUEST_TIMEOUT=30
GUILDBRIDGE_MAX_RETRIES=5
GUILDBRIDGE_USER_AGENT="GuildBridge/0.1 (+https://github.com/Yunushan/guildbridge)"

# Discord
DISCORD_API_BASE=https://discord.com/api/v10
DISCORD_BOT_TOKEN=
# DISCORD_TOKEN=  # accepted alias

# Fluxer
FLUXER_API_BASE=https://api.fluxer.app/v1
FLUXER_BOT_TOKEN=
# FLUXER_TOKEN=  # accepted alias

# Stoat / Revolt-compatible deployments
STOAT_API_BASE=https://api.stoat.chat
STOAT_BOT_TOKEN=
# Some Stoat role-management routes may require user/session auth instead of bot auth.
# Prefer a dedicated migration/admin account and keep this token out of templates, plans, and screenshots.
# STOAT_SESSION_TOKEN=
# STOAT_TOKEN=   # accepted alias
# REVOLT_API_BASE=
# REVOLT_SESSION_TOKEN=
# REVOLT_TOKEN=

# Spacebar / Fosscord-compatible deployments
SPACEBAR_API_BASE=https://api.spacebar.chat/api/v9
SPACEBAR_BOT_TOKEN=
# SPACEBAR_TOKEN=       # accepted alias
# FOSSCORD_API_BASE=    # accepted alias
# FOSSCORD_BOT_TOKEN=   # accepted alias
# FOSSCORD_TOKEN=       # accepted alias

# Daccord
DACCORD_API_BASE=http://localhost:3000/api/v1
DACCORD_BOT_TOKEN=
DACCORD_AUTH_SCHEME=Bot
# DACCORD_TOKEN=        # accepted alias
# DACCORD_AUTH_SCHEME=Bearer  # use when your Daccord token is a user bearer token

# Matrix / Element
MATRIX_BASE_URL=https://matrix.org
MATRIX_SERVER_NAME=matrix.org
MATRIX_ACCESS_TOKEN=
# ELEMENT_MATRIX_BASE_URL=  # accepted alias
# ELEMENT_ACCESS_TOKEN=     # accepted alias

# Rocket.Chat
ROCKET_CHAT_API_BASE=http://localhost:3000/api/v1
ROCKET_CHAT_AUTH_TOKEN=
ROCKET_CHAT_USER_ID=
# ROCKETCHAT_API_BASE=      # accepted alias
# ROCKETCHAT_AUTH_TOKEN=    # accepted alias
# ROCKETCHAT_USER_ID=       # accepted alias

# Mumble / Murmur admin API bridge
# Mumble's voice protocol is not an HTTP management API. Point this at your
# Murmur/Ice/gRPC-to-HTTP admin bridge that exposes server, channel, group, and ACL routes.
MUMBLE_API_BASE=http://localhost:64738/api/v1
MUMBLE_API_TOKEN=

# Mattermost
MATTERMOST_API_BASE=http://localhost:8065/api/v4
MATTERMOST_TOKEN=
# MATTERMOST_PERSONAL_ACCESS_TOKEN=  # accepted alias

# Zulip
ZULIP_API_BASE=https://chat.zulip.org/api/v1
ZULIP_EMAIL=
ZULIP_API_KEY=
# ZULIP_BOT_EMAIL=    # accepted alias
# ZULIP_BOT_API_KEY=  # accepted alias
